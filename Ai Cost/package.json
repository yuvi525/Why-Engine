{
  "name": "vela",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "seed:demo": "tsx apps/proxy/src/demo-seeder.ts",
    "db:reset": "node -e \"const fs=require('fs');const p='apps/proxy/vela.db';if(fs.existsSync(p)){fs.unlinkSync(p);console.log('DB reset')}else{console.log('No DB found')}\""
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
